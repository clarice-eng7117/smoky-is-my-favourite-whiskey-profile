Region = case_when(
Easting < 150000 ~ "Islay",
Easting < 210000 & Northing < 630000 ~ "Campbeltown",
Northing < 700000 ~ "Lowlands",
Easting >= 300000 & Easting <= 350000 & Northing >= 820000 & Northing <= 860000 ~ "Speyside",
TRUE ~ "Highlands"
),
Region = as.factor(Region)
)
