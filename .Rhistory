# install.packages("spdep")
library(spdep)
# install.packages("spdep")
library(spdep)
# 1. Extract geographic coordinates from the Projected CRS (British National Grid)
coords <- st_coordinates(whisky)
# 2. FIX: Jitter coordinates slightly to resolve identical points
#a tiny, random micro-displacement (e.g., 0.1 meters) is introduced to overlapping points
set.seed(42) # Set seed to ensure the random displacement is exactly reproducible
coords_jittered <- jitter(coords, factor = 0.001)
# 3. Find the 4 nearest neighbors using the clean, jittered coordinates
# (This completely bypasses the kd_tree warning)
whisky_knn <- knearneigh(coords_jittered, k = 4)
whisky_nb  <- knn2nb(whisky_knn)
# 4. Create row-standardized spatial weights
whisky_weights <- nb2listw(whisky_nb, style = "W")
# 5. GENERATE THE GRAPH: Force sequential plotting
# First, draw the underlying spatial point geometry to instantiate the plot canvas
plot(st_geometry(whisky), col = "darkgray", main = "4-Nearest Neighbors Network Graph", pch = 16)
# Next, overlay the network lines onto the active canvas using our jittered coordinates
plot(whisky_nb, coords_jittered, add = TRUE, col = "red", lwd = 1.5)
